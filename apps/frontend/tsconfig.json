{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@collabcode/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@collabcode/shared-utils": ["../../packages/shared-utils/src/index.ts"],
      "@collabcode/shared-config": ["../../packages/shared-config/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
