# NODE_ENV: Frontend runtime environment.
NODE_ENV=<set-in-.env>
# LOG_LEVEL: Frontend log verbosity for local debugging.
LOG_LEVEL=<set-in-.env>
# LOGTAIL_SOURCE_TOKEN: Optional frontend Logtail source token.
LOGTAIL_SOURCE_TOKEN=<set-in-.env>
# VITE_API_BASE_URL: API gateway base URL used by the frontend.
VITE_API_BASE_URL=<set-in-.env>
# VITE_COLLAB_WS_URL: Collaboration websocket URL.
VITE_COLLAB_WS_URL=<set-in-.env>
# VITE_EXECUTION_API_URL: Execution API URL.
VITE_EXECUTION_API_URL=<set-in-.env>
