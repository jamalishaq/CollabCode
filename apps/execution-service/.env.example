# PORT: HTTP port for execution-service.
PORT=4001

# JWT_SECRET: shared secret used to validate bearer JWTs.
JWT_SECRET=replace-me

# QSTASH_URL: QStash publish endpoint for execution.completed.
QSTASH_URL=https://qstash.upstash.io/v2/publish/your-topic

# QSTASH_TOKEN: bearer token used to authenticate to QStash.
QSTASH_TOKEN=replace-me

# MAX_CONCURRENT_EXECUTIONS: max concurrent executions before returning 503.
MAX_CONCURRENT_EXECUTIONS=10
