# PORT: HTTP port for execution-service.
PORT=<set-in-.env>
# APP_ENV: Runtime environment.
APP_ENV=<set-in-.env>
# LOG_LEVEL: Structured log level.
LOG_LEVEL=<set-in-.env>
# LOGTAIL_SOURCE_TOKEN: Logtail source token for centralized logs.
LOGTAIL_SOURCE_TOKEN=<set-in-.env>
# REDIS_ADDR: Redis host:port.
REDIS_ADDR=<set-in-.env>
# QSTASH_BROKERS: Comma-separated QStash brokers.
QSTASH_BROKERS=<set-in-.env>
# QSTASH_USERNAME: QStash SASL username.
QSTASH_USERNAME=<set-in-.env>
# QSTASH_PASSWORD: QStash SASL password.
QSTASH_PASSWORD=<set-in-.env>
# QSTASH_SSL: Whether QStash SSL is required.
QSTASH_SSL=<set-in-.env>
# MAX_EXECUTION_TIMEOUT_MS: Hard timeout in milliseconds.
MAX_EXECUTION_TIMEOUT_MS=<set-in-.env>
