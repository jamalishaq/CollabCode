# PORT: HTTP listening port for file-service.
PORT=<set-in-.env>
# NODE_ENV: Runtime environment (development|staging|production).
NODE_ENV=<set-in-.env>
# LOG_LEVEL: Structured log level.
LOG_LEVEL=<set-in-.env>
# LOGTAIL_SOURCE_TOKEN: Logtail source token for centralized logs.
LOGTAIL_SOURCE_TOKEN=<set-in-.env>
# DATABASE_URL: Postgres connection string with SSL required in production.
DATABASE_URL=<set-in-.env>
# REDIS_URL: Redis connection TLS URL for file locks.
REDIS_URL=<set-in-.env>
# QSTASH_URL: QStash URL.
QSTASH_URL=<set-in-.env>
# QSTASH_TOKEN: QStash token.
QSTASH_TOKEN=<set-in-.env>
# QSTASH_CURRENT_SIGNING_KEY: QStash current signing key.
QSTASH_CURRENT_SIGNING_KEY=<set-in-.env>
# QSTASH_NEXT_SIGNING_KEY: QStash next signing key.
QSTASH_NEXT_SIGNING_KEY=<set-in-.env>
# LOCK_TTL_SECONDS: File lock TTL in seconds.
LOCK_TTL_SECONDS=<set-in-.env>
# R2_ACCOUNT_ID: Cloudflare R2 account identifier.
R2_ACCOUNT_ID=<set-in-.env>
# R2_ACCESS_KEY_ID: Cloudflare R2 access key.
R2_ACCESS_KEY_ID=<set-in-.env>
# R2_SECRET_ACCESS_KEY: Cloudflare R2 secret access key.
R2_SECRET_ACCESS_KEY=<set-in-.env>
# R2_BUCKET_NAME: R2 bucket for file contents.
R2_BUCKET_NAME=<set-in-.env>
# R2_PUBLIC_URL: Public base URL for stored files.
R2_PUBLIC_URL=<set-in-.env>
