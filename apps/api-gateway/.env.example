# PORT: HTTP listening port for api-gateway.
PORT=<set-in-.env>
# NODE_ENV: Runtime environment (development|staging|production).
NODE_ENV=<set-in-.env>
# LOG_LEVEL: Structured log level.
LOG_LEVEL=<set-in-.env>
# LOGTAIL_SOURCE_TOKEN: Logtail source token for centralized logs.
LOGTAIL_SOURCE_TOKEN=<set-in-.env>
# JWT_SECRET: Secret used to verify incoming bearer tokens.
JWT_SECRET=<set-in-.env>
# AUTH_SERVICE_URL: Upstream auth-service URL.
AUTH_SERVICE_URL=https://collabcode-auth.onrender.com
# WORKSPACE_SERVICE_URL: Upstream workspace-service URL.
WORKSPACE_SERVICE_URL=https://collabcode-workspace.onrender.com
# FILE_SERVICE_URL: Upstream file-service URL.
FILE_SERVICE_URL=https://collabcode-file.onrender.com
# NOTIFICATION_SERVICE_URL: Upstream notification-service URL.
NOTIFICATION_SERVICE_URL=https://collabcode-notification.onrender.com
# COLLABORATION_SERVICE_URL: Upstream collaboration-service URL.
COLLABORATION_SERVICE_URL=https://collabcode-collaboration.onrender.com/
# EXECUTION_SERVICE_URL: Upstream execution-service URL.
EXECUTION_SERVICE_URL=https://collabcode-execution.onrender.com/
# QSTASH_URL: QStash URL.
QSTASH_URL=<set-in-.env>
# QSTASH_TOKEN: QStash token.
QSTASH_TOKEN=<set-in-.env>
# QSTASH_CURRENT_SIGNING_KEY: QStash current signing key.
QSTASH_CURRENT_SIGNING_KEY=<set-in-.env>
# QSTASH_NEXT_SIGNING_KEY: QStash next signing key.
QSTASH_NEXT_SIGNING_KEY=<set-in-.env>
# REDIS_URL: Redis connection URL.
REDIS_URL=<set-in-.env>
