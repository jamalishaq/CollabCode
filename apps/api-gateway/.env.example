# PORT: HTTP listening port for api-gateway.
PORT=3000
# NODE_ENV: Runtime environment (development|staging|production).
NODE_ENV=development
# JWT_SECRET: Secret used to verify incoming bearer tokens.
JWT_SECRET=change-me
# AUTH_SERVICE_URL: Upstream auth-service URL.
AUTH_SERVICE_URL=http://localhost:3001
# WORKSPACE_SERVICE_URL: Upstream workspace-service URL.
WORKSPACE_SERVICE_URL=http://localhost:3002
# FILE_SERVICE_URL: Upstream file-service URL.
FILE_SERVICE_URL=http://localhost:3003
# NOTIFICATION_SERVICE_URL: Upstream notification-service URL.
NOTIFICATION_SERVICE_URL=http://localhost:3004
# KAFKA_BROKERS: Comma-separated Kafka broker addresses.
KAFKA_BROKERS=localhost:9092
# REDIS_URL: Redis connection URL used for rate limiting/session reads.
REDIS_URL=redis://localhost:6379
