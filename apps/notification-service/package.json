{
  "name": "@collabcode/notification-service",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon -L",
    "build": "pnpm --filter @collabcode/shared-types build && pnpm --filter @collabcode/shared-config build && pnpm --filter @collabcode/shared-utils build && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"No unit tests yet\"",
    "test:integration": "echo \"No integration tests yet\"",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@collabcode/shared-types": "workspace:*",
    "@collabcode/shared-utils": "workspace:*",
    "@collabcode/shared-config": "workspace:*",
    "@upstash/qstash": "^2.9.0",
    "fastify": "^5.8.2",
    "helmet": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "pino-pretty": "^13.1.3"
  }
}
